{
  "expo": {
    "name": "SachaFrontend",
    "slug": "sachafrontend",
    "scheme": "biosacha",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0d1f1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sacha.frontend"
    },
    "android": {
      "package": "com.sacha.frontend"
    },
    "plugins": [
      "expo-audio",
      "expo-web-browser"
    ]
  }
}
